        function changeWeek(week) {
            // 버튼 스타일 업데이트
            for(let i=1; i<=5; i++) {
                const btn = document.getElementById('btn-week-' + i);
                if(i === week) {
                    btn.classList.remove('inactive');
                    btn.classList.add('active');
                } else {
                    btn.classList.remove('active');
                    btn.classList.add('inactive');
                }
            }

            // 데이터 렌더링
            const data = menuData[week];
            
            for(let i=0; i<5; i++) {
                // 헤더 날짜 처리
                let th = document.getElementById('th-day' + (i+1));
                th.innerHTML = data.days[i].replace(' ', '<br/><span class="text-xs text-rose-500 font-normal">') + (data.days[i].includes(' ') ? '</span>' : '');

                // 셀 렌더링
                document.getElementById('td-ch-' + (i+1)).innerHTML = renderCell(data.cho[i]);
                document.getElementById('td-jung-' + (i+1)).innerHTML = renderCell(data.jung[i]);
                document.getElementById('td-hu-' + (i+1)).innerHTML = renderCell(data.hu[i]);
            }
        }

        // 각 셀의 내용을 HTML로 예쁘게 조합해주는 함수
        function renderCell(item) {
            if(!item) return '<span class="text-neutral-300">-</span>';
            
            const [menuName, allergy, nut] = item;
            
            // 고기류, 생선류 텍스트 색상 강조
            let highlightedName = menuName;
            if(highlightedName.includes('쇠고기')) {
                highlightedName = highlightedName.replace('쇠고기', '<span class="text-rose-600 font-bold">쇠고기</span>');
            } else if(highlightedName.includes('닭가슴살')) {
                highlightedName = highlightedName.replace('닭가슴살', '<span class="text-amber-600 font-bold">닭가슴살</span>');
            } else if(highlightedName.includes('닭')) {
                highlightedName = highlightedName.replace('닭', '<span class="text-amber-600 font-bold">닭</span>');
            } else if(highlightedName.includes('흰살생선')) {
                highlightedName = highlightedName.replace('흰살생선', '<span class="text-blue-600 font-bold">흰살생선</span>');
            }

            // 알레르기 번호 뱃지 (있을 경우에만 렌더링)
            const allergyHtml = allergy 
                ? `<span class="inline-block bg-rose-100 text-rose-600 text-[10px] font-bold px-1 rounded-full ml-0.5 align-text-top leading-none py-0.5">${allergy}</span>` 
                : '';

            // 칼로리/단백질 뱃지
            const nutHtml = `<div class="mt-2 inline-flex items-center gap-1 bg-neutral-100/80 text-neutral-500 text-[11px] px-2 py-1 rounded-md border border-neutral-200">
                                <i class="ph-fill ph-fire text-orange-400"></i> ${nut}
                             </div>`;

            return `<div class="flex flex-col items-center justify-center h-full">
                        <div class="font-bold text-neutral-800 break-keep leading-snug">${highlightedName}${allergyHtml}</div>
                        ${nutHtml}
                    </div>`;
        }

        // 초기 화면 세팅 (1주차)
        changeWeek(1);
    </script>
</body>
</html>


